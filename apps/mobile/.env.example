# Variables de entorno para la app móvil LMCU ERP
# El prefijo EXPO_PUBLIC_ es REQUERIDO para que Expo las exponga al bundle del cliente

# URL del API backend NestJS
# Desarrollo local: usa la IP real de tu máquina (no localhost, el emulador Android no resuelve localhost)
EXPO_PUBLIC_API_URL=http://192.168.1.X:3001

# URL del entorno de producción (Render)
# EXPO_PUBLIC_API_URL=https://tu-api.onrender.com

# Supabase (si se requiere acceso directo desde mobile en el futuro)
# EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
