# ══════════════════════════════════════════════════════════════════════════════
# 🗄️  Base de Datos — Supabase PostgreSQL
# ══════════════════════════════════════════════════════════════════════════════
#
# 🔑 PRODUCCIÓN (Render / VPS)
# Usar el pooler de Supabase (Transaction Mode, puerto 6543).
# Parámetros recomendados para Prisma + PgBouncer:
#   • pgbouncer=true          → Desactiva prepared statements (requerido por PgBouncer)
#   • connection_limit=1      → Evita saturar el pool (Prisma abre N conexiones por defecto)
#   • connect_timeout=30      → Tolerar cold starts de Render Free Tier (~15-20s)
#   • pool_timeout=30         → Espera máxima por una conexión del pool
#   • sslmode=require         → Cifrado obligatorio en producción
#
DATABASE_URL="postgresql://postgres.momfvvdmnpvnafxglhme:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&connect_timeout=30&pool_timeout=30&sslmode=require"

# 🔗 DIRECT_URL — Conexión directa (solo para migraciones)
# Puerto 5432 (Session Mode), sin pasar por PgBouncer.
# Prisma lo usa internamente para `prisma migrate deploy` y `prisma db push`.
# ⚠️  NO usar esta URL para queries en runtime.
#
DIRECT_URL="postgresql://postgres.momfvvdmnpvnafxglhme:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# 🏠 DESARROLLO LOCAL (descomentar para usar PostgreSQL local)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/erp_lmcu"

# ══════════════════════════════════════════════════════════════════════════════
# 🔐 Supabase — Autenticación
# ══════════════════════════════════════════════════════════════════════════════
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."
SUPABASE_JWT_SECRET="your-jwt-secret-from-supabase-settings"

# ══════════════════════════════════════════════════════════════════════════════
# ⚙️  Aplicación
# ══════════════════════════════════════════════════════════════════════════════
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"
